NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_APP_NAME=Mini's Pastries

# Login mode: omit this line or set any value other than false for magic links.
magiclink=false

# Server-only key used to sign the employee offline-access snapshot cookie.
OFFLINE_SNAPSHOT_SIGNING_KEY=replace_with_a_long_random_secret

# Booth map search and previews use OpenStreetMap. No map API key is required.
